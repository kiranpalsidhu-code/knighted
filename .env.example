# Knighted — environment variables
# Copy to .env for local use, or set these in your host's dashboard (e.g. Railway).
# NEVER commit real secret values. This file is a template only.

# ---- Required to run ----

# Postgres connection string. On Railway, reference the Postgres plugin's value:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://user:password@host:5432/knighted

# Port the server listens on. Hosts (Railway) set this automatically at runtime.
PORT=5000

# ---- Auth: Clerk (https://dashboard.clerk.com) ----
# Same publishable key goes in BOTH of these (server + client build).
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# ---- AI: Anthropic (https://console.anthropic.com) ----
# Option A — direct Anthropic API (simplest):
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6            # optional override
# Option B — AWS Bedrock instead of the direct API (leave ANTHROPIC_API_KEY unset):
# AWS_BEDROCK_REGION=ca-central-1
# AWS_BEDROCK_ACCESS_KEY_ID=xxxx
# AWS_BEDROCK_SECRET_ACCESS_KEY=xxxx
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ---- Email: Resend (https://resend.com) ----
# Required for the server to boot (the email client is created at startup).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# ---- Payments: Stripe (optional — billing returns 503 if unset) ----
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
# STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

# ---- Static hosting overrides (optional) ----
# The API server auto-serves the built web apps from the monorepo by default.
# Override only if your deploy layout differs:
# RESUME_READY_DIST=/app/artifacts/resume-ready/dist/public
# KNIGHTED_JOBS_DIST=/app/artifacts/knighted-jobs/dist/public
